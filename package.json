{
  "name": "react-native-nitro-image-marker",
  "version": "0.2.0",
  "description": "High-performance image watermarking for React Native. Add text, image overlays, tile watermarks, crop, blur regions, filters (grayscale, brightness, contrast), and batch process images. Built with Nitro Modules for native speed on iOS and Android.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "clean": "git clean -dfX",
    "release": "semantic-release",
    "build": "npm run typecheck && bob build",
    "codegen": "npx nitrogen --logLevel=\"debug\" && npm run build && node post-script.js"
  },
  "keywords": [
    "react-native",
    "react-native-image-marker",
    "react-native-watermark",
    "react-native-image-watermark",
    "react-native-text-watermark",
    "react-native-image-overlay",
    "react-native-image-stamp",
    "react-native-photo-watermark",
    "react-native-image-editor",
    "react-native-image-filter",
    "react-native-image-crop",
    "react-native-image-blur",
    "react-native-batch-image",
    "react-native-tile-watermark",
    "nitro-modules",
    "nitro",
    "image-watermark",
    "image-marker",
    "watermark",
    "image-overlay",
    "image-stamp",
    "photo-watermark",
    "text-watermark",
    "image-annotation",
    "image-processing",
    "image-crop",
    "image-filter",
    "image-blur",
    "batch-processing",
    "tile-watermark",
    "grayscale",
    "brightness",
    "contrast",
    "blur-region",
    "watermark-text",
    "watermark-image",
    "logo-overlay",
    "timestamp-photo",
    "proof-of-delivery",
    "confidential-stamp",
    "ios",
    "android",
    "expo",
    "expo-plugin"
  ],
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "cpp",
    "nitrogen/generated",
    "nitro.json",
    "react-native.config.js",
    "app.plugin.js",
    "*.podspec",
    "README.md"
  ],
  "workspaces": [
    "example"
  ],
  "repository": "https://github.com/devprahlad/react-native-nitro-image-marker.git",
  "author": "Prahlad",
  "license": "MIT",
  "bugs": "https://github.com/devprahlad/react-native-nitro-image-marker/issues",
  "homepage": "https://github.com/devprahlad/react-native-nitro-image-marker",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@jamesacarr/eslint-formatter-github-actions": "^0.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "19.2.0",
    "nitrogen": "0.35.2",
    "react": "19.2.0",
    "react-native": "0.83",
    "react-native-builder-bob": "^0.40.17",
    "react-native-nitro-modules": "0.35.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "semantic-release": "^25.0.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}