{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitroimagemarker"
  ],
  "ios": {
    "iosModuleName": "NitroImageMarker"
  },
  "android": {
    "androidNamespace": [
      "nitroimagemarker"
    ],
    "androidCxxLibName": "NitroImageMarker"
  },
  "autolinking": {
    "NitroImageMarker": {
      "swift": "HybridNitroImageMarker",
      "kotlin": "HybridNitroImageMarker"
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}