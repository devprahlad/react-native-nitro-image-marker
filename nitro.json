{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitroimagemarker"
  ],
  "ios": {
    "iosModuleName": "NitroImageMarker"
  },
  "android": {
    "androidNamespace": [
      "nitroimagemarker"
    ],
    "androidCxxLibName": "NitroImageMarker"
  },
  "autolinking": {
    "NitroImageMarker": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridNitroImageMarker"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridNitroImageMarker"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules",
    "example",
    "expo-example"
  ]
}